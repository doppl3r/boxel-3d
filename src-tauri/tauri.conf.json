{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Boxel 3D",
  "version": "2.8.3",
  "identifier": "com.boxel3d.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Boxel 3D",
        "width": 640,
        "height": 360,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../public/png/icon32.png",
      "../public/png/icon128.png",
      "../public/png/icon256.png",
      "../public/png/icon512.png"
    ],
    "resources": [
      "../public/png/workshop-thumbnail.png"
    ]
  }
}
