{
  "name": "boxel-3d",
  "version": "2.6.5",
  "description": "Boxel 3D is the 3rd release of your favorite box jumping game made by the developers of Boxel Rebound.",
  "author": "Jacob DeBenedetto",
  "main": "main.mjs",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "dist-electron": "vite build && electron-builder",
    "dist-extension": "vite build && node extension.js",
    "dist-android": "vite build && npx cap sync",
    "generate-assets": "npx @capacitor/assets generate --android --assetPath files/png/assets --iconBackgroundColor #9016ff --splashBackgroundColor #9016ff --splashBackgroundColorDark #9016ff",
    "start": "vite build && electron ."
  },
  "build": {
    "appId": "com.electron.boxel.3d",
    "artifactName": "${productName}.${ext}",
    "directories": {
      "output": "dist"
    },
    "extraFiles": [
      "public/png/workshop-thumbnail.png"
    ],
    "icon": "png/icon512.png",
    "files": [
      "build",
      "main.mjs",
      "preload.mjs"
    ],
    "mac": {
      "category": "public.app-category.arcade-games",
      "target": {
        "target": "default",
        "arch": [
          "x64"
        ]
      }
    },
    "win": {
      "target": "portable"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@capacitor/android": "^7.2.0",
    "@capacitor/app": "^7.0.1",
    "@capacitor/core": "^7.2.0",
    "@capacitor/filesystem": "^7.0.1",
    "@capacitor/ios": "^7.2.0",
    "@tweenjs/tween.js": "^25.0.0",
    "electron-store": "^10.0.1",
    "file-saver": "^2.0.5",
    "matter-js": "^0.19.0",
    "peerjs": "^1.5.4",
    "sanitize-html": "^2.16.0",
    "sass": "^1.87.0",
    "steamworks.js": "^0.4.0",
    "three": "^0.176.0",
    "vue": "^3.5.13",
    "vue-i18n": "^11.1.3",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.2.0",
    "@dimforge/rapier3d": "^0.16.2",
    "@vitejs/plugin-vue": "^5.2.3",
    "electron": "^36.2.0",
    "electron-builder": "^26.0.12",
    "gulp": "^5.0.0",
    "gulp-zip": "^6.1.0",
    "vite": "^6.3.5",
    "vite-plugin-top-level-await": "^1.5.0",
    "vite-plugin-wasm": "^3.4.1"
  }
}
