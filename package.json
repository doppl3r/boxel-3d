{
  "name": "boxel-golf",
  "version": "0.0.1",
  "description": "Boxel Golf is a multiplayer golf game packed with challenging courses, silly hats, and a powerful level builder. Create your very own courses and share them with your friends. No internet? No problem. Play offline and beat your high scores.",
  "author": "Jacob DeBenedetto",
  "main": "main.js",
  "keywords": [
    "Boxel",
    "Golf"
  ],
  "scripts": {
    "start": "node gulp-build.js && electron .",
    "build-chrome": "node gulp-build.js && node gulp-chrome.js",
    "pack": "node gulp-build.js && electron-builder --dir",
    "dist": "node gulp-build.js && electron-builder"
  },
  "postinstall": "electron-builder install-app-deps",
  "build": {
    "appId": "com.electron.boxel.golf",
    "icon": "img/png/icon256.png",
    "files": [
      "main.js",
      "build"
    ],
    "mac": {
      "category": "public.app-category.sports-games"
    },
    "win": {
      "target": "portable"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "electron": "^19.0.4",
    "electron-builder": "^23.1.0",
    "gulp": "^4.0.2",
    "gulp-replace": "^1.1.3",
    "gulp-zip": "^5.1.0"
  }
}
