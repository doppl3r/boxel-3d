{
  "name": "boxel-3d",
  "version": "2.8.8",
  "description": "Boxel 3D is the 3rd release of your favorite box jumping game made by the developers of Boxel Rebound.",
  "author": "Jacob DeBenedetto",
  "main": "src/js/Main.js",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build-android": "vite build && npx cap sync",
    "build-extension": "vite build && node files/js/build-extension.js",
    "build-tauri": "tauri build",
    "dev": "vite",
    "generate-assets": "npx @capacitor/assets generate --android --assetPath files/png/assets --iconBackgroundColor #9016ff --splashBackgroundColor #9016ff --splashBackgroundColorDark #9016ff",
    "start": "tauri dev",
    "tauri": "tauri"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/filesystem": "^8.1.2",
    "@tauri-apps/api": "^2.8.0",
    "@tweenjs/tween.js": "^25.0.0",
    "file-saver": "^2.0.5",
    "matter-js": "^0.19.0",
    "peerjs": "^1.5.5",
    "sanitize-html": "^2.17.2",
    "three": "^0.183.2",
    "vue": "^3.5.32",
    "vue-i18n": "^11.3.2",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.0",
    "@dimforge/rapier3d": "^0.19.3",
    "@tauri-apps/cli": "^2.10.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "gulp": "^5.0.1",
    "gulp-zip": "^6.1.0",
    "sass": "^1.99.0",
    "vite": "^8.0.8",
    "vite-plugin-wasm": "^3.6.0"
  }
}
