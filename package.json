{
  "name": "boxel-3d",
  "version": "2.2.3",
  "description": "Boxel 3D is the 3rd release of your favorite box jumping game made by the developers of Boxel Rebound.",
  "author": "Jacob DeBenedetto",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "dist": "vite build && electron-builder",
    "start": "vite build && electron ."
  },
  "build": {
    "appId": "com.electron.boxel.3d",
    "artifactName": "${productName}.${ext}",
    "directories": {
      "output": "dist"
    },
    "icon": "png/icon512.png",
    "files": [
      "main.js",
      "preload.js",
      "build"
    ],
    "mac": {
      "category": "public.app-category.arcade-games",
      "target": {
        "target": "default",
        "arch": [
          "x64"
        ]
      }
    },
    "win": {
      "target": "portable"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@tweenjs/tween.js": "^25.0.0",
    "file-saver": "^2.0.5",
    "matter-js": "^0.19.0",
    "peerjs": "^1.5.4",
    "sanitize-html": "^2.13.0",
    "sass": "^1.78.0",
    "three": "^0.168.0",
    "vue": "^3.5.2"
  },
  "devDependencies": {
    "@dimforge/rapier3d": "^0.14.0",
    "@vitejs/plugin-vue": "^5.1.3",
    "electron": "^32.0.2",
    "electron-builder": "^25.0.5",
    "vite": "^5.4.3",
    "vite-plugin-top-level-await": "^1.4.4",
    "vite-plugin-wasm": "^3.3.0"
  }
}
