{
  "name": "boxel-3d",
  "version": "2.5.4",
  "description": "Boxel 3D is the 3rd release of your favorite box jumping game made by the developers of Boxel Rebound.",
  "author": "Jacob DeBenedetto",
  "main": "main.mjs",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "dist": "vite build && electron-builder",
    "start": "vite build && electron ."
  },
  "build": {
    "appId": "com.electron.boxel.3d",
    "artifactName": "${productName}.${ext}",
    "directories": {
      "output": "dist"
    },
    "extraFiles": [
      "public/png/workshop-thumbnail.png"
    ],
    "icon": "png/icon512.png",
    "files": [
      "build",
      "main.mjs",
      "preload.mjs"
    ],
    "mac": {
      "category": "public.app-category.arcade-games",
      "target": {
        "target": "default",
        "arch": [
          "x64"
        ]
      }
    },
    "win": {
      "target": "portable"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@tweenjs/tween.js": "^25.0.0",
    "electron-store": "^10.0.1",
    "file-saver": "^2.0.5",
    "matter-js": "^0.19.0",
    "peerjs": "^1.5.4",
    "sanitize-html": "^2.14.0",
    "sass": "^1.85.1",
    "steamworks.js": "^0.4.0",
    "three": "^0.174.0",
    "vue": "^3.5.13",
    "vue-i18n": "^11.1.2",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@dimforge/rapier3d": "^0.15.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "electron": "^34.3.0",
    "electron-builder": "^25.1.8",
    "vite": "^6.2.2",
    "vite-plugin-top-level-await": "^1.5.0",
    "vite-plugin-wasm": "^3.4.1"
  }
}
