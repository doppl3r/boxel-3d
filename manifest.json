{
    "manifest_version": 2,
  
    "name": "Boxel 3D",
    "description": "Box jumping in 3D",
    "version": "0.1.4",
    "browser_action": {
      "default_popup": "index.html",
      "default_title": "Boxel 3D"
    },
    "icons": { 
      "16": "img/png/icon16.png", 
      "48": "img/png/icon48.png", 
      "128": "img/png/icon128.png"
    },
    "permissions": [
      "storage"
    ]
  }